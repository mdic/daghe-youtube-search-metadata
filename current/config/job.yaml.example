job_name: "daghe-youtube-search-metadata"

search_strategy:
  pool_size: 100        # Candidates to fetch per time window
  pool_size_max: 500    # Maximum expansion limit
  pool_size_step: 100   # Increment per fallback step

# Temporal stratification configuration
time_slicing:
  enabled: true
  start_date: "2023-01-01"
  end_date: "2025-12-31"
  interval: "quarter"   # Options: month, quarter, year

# Define multiple search tasks
searches:
  - query: "Linux automation tutorial 2024"
    max_results: 5
    # Search-specific options (e.g. filter by date)
    extra_ydl_opts:
      dateafter: "20240101"
      datebefore: "20241231"

  - query: "Python uv tutorial"
    max_results: 3
    # This search has no specific date limits

paths:
  data_dir: "${BASE_DIR}/jobs/daghe-youtube-search-metadata/data"
  archive_file: "${BASE_DIR}/jobs/daghe-youtube-search-metadata/data/processed_videos.txt"
  telegram_helper: "${BASE_DIR}/bin/telegram-notify.sh"

output:
  pretty_json: true
  overwrite_existing_json: false
  # Se true usa l'ID (es. 0FuF-yE9Kqs.json)
  # Se false usa il titolo (es. Come installare Linux.json)
  use_id_filenames: true

yt_dlp:
  # Path to the cookies file, using the dynamic placeholder
  cookie_file: "${BASE_DIR}/config/cookies/daghe-youtube-search-metadata.txt"

  # Extra arguments mapped to yt-dlp Python API keys
  # See: https://github.com/yt-dlp/yt-dlp/blob/master/yt_dlp/YoutubeDL.py#L141
  # These are for yt-dlp general behaviour
  extra_ydl_opts:
    sleep_interval_requests: 1
    verbose: true
    nocheckcertificate: false
    # (Opzionale) Rende l'attesa casuale tra 5 e 10 secondi
    max_sleep_interval_requests: 10

logging:
  level: "INFO"

git:
  enabled: true
  branch: "main"
  auto_push: true
  commit_message_template: "youtube-search-metadata: {new_count} new metadata files for query '{query}'"

telegram:
  enabled: true
  notify_on_success: true
  notify_on_partial: true
  notify_on_failure: true
  level_on_success: "info"
  level_on_partial: "error"
  level_on_failure: "error"

runtime:
  continue_on_video_error: true
